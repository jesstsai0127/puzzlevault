{
  "formatVersion": 1,
  "id": "yuan_ling",
  "nameKey": "monster.yuan_ling.name",
  "spriteRef": "mon_yuan_ling",
  "maxHp": 2,
  "moveRange": 1,
  "skillIds": ["spirit_bolt"],
  "aiRules": [
    {
      "when": { "kind": "targetInRange", "target": "nearestPlayer", "range": 1 },
      "action": { "kind": "moveAway", "target": "nearestPlayer" }
    },
    {
      "when": { "kind": "targetInRange", "target": "nearestBaseTile", "range": 3 },
      "action": { "kind": "useSkill", "skillId": "spirit_bolt" }
    },
    {
      "when": { "kind": "always" },
      "action": { "kind": "moveToward", "target": "nearestBaseTile" }
    }
  ]
}
