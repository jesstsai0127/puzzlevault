{
  "name": "puzzlevault",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"vite\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p core",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "phaser": "^3.85.0"
  }
}
